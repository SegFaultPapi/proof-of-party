# Copia este archivo a .env en esta misma carpeta (contracts/.env)
# ⚠️  Nunca subas .env a git — está en .gitignore

# ── Monad Testnet ───────────────────────────────────────────
# RPC: https://testnet-rpc.monad.xyz
# Chain ID: 10143
# Explorer: https://testnet.monadexplorer.com
# Faucet de MON (gas): https://faucet.monad.xyz
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Llave privada del deployer (sin 0x)
PRIVATE_KEY=

# Opcional: API key para verificar en el explorer
MONAD_VERIFIER_KEY=placeholder

# ── Direcciones desplegadas ─────────────────────────────────
# Pon las addresses aquí después del primer deploy
USDC_ADDRESS=
AGENT_ADDRESS=
PROOF_OF_PARTY_ADDRESS=

# ── Parámetros del contrato ─────────────────────────────────
# REWARD_AMOUNT en unidades de USDC (6 decimales), ej: 10000000 = 10 USDC
REWARD_AMOUNT=10000000
# Nivel mínimo de cruda (0-100) para cobrar, ej: 70
MINIMUM_SCORE=70
